# ── RMAP Chatbot Secrets ──
# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.

# ── Dify API ──

# Dify API base URL (with /v1 for dataset API calls)
DIFY_API_URL=http://rmap-chatbot-demo-dify/v1

# Dify console base URL (without /v1, for admin scripts)
DIFY_BASE_URL=http://rmap-chatbot-demo-dify

# App API key (for chat / workflow runtime endpoints, prefix "app-")
DIFY_APP_API_KEY=app-<your-app-key>

# Dataset API key (for knowledge base / document / metadata endpoints, prefix "dataset-")
DIFY_DATASET_API_KEY=dataset-<your-dataset-key>

# Legacy alias – workflow code nodes use this name.
DIFY_API_KEY=dataset-<your-dataset-key>

# App ID for the RMAP Chatbot workflow
DIFY_APP_ID=<your-app-id>

# Default dataset ID used by workflow scripts and uploaders
DIFY_DATASET_ID=5a231cec-21bf-40b9-86c8-87b9d01bca74

# ── Dify Console Login (for admin scripts: import/export/debug) ──

DIFY_CONSOLE_EMAIL=<your-email>
DIFY_CONSOLE_PASSWORD_B64=<your-base64-encoded-password>
DIFY_CONSOLE_LOGIN_LANGUAGE=en-US
DIFY_CONSOLE_REMEMBER_ME=true
