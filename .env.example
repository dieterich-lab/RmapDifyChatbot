# ── RMAP Chatbot Secrets ──
# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.

# Dify API base URL
DIFY_API_URL=http://rmap-chatbot-demo-dify/v1

# App API key (for chat / workflow runtime endpoints, prefix "app-")
DIFY_APP_API_KEY=app-<your-app-key>

# Dataset API key (for knowledge base / document / metadata endpoints, prefix "dataset-")
DIFY_DATASET_API_KEY=dataset-<your-dataset-key>

# Legacy alias – workflow code nodes use this name.
# Set it to the dataset key so knowledge-retrieval calls work.
DIFY_API_KEY=dataset-<your-dataset-key>

# Default dataset ID used by workflow scripts and uploaders
DIFY_DATASET_ID=<your-dataset-id>
